---
import Section from "../components/Section.astro";
import { profile } from "../content/profile";
const year = new Date().getFullYear();
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={`${profile.name} - ${profile.role}`} />
    <title>{profile.name}</title>
  </head>
  <body>
    <nav class="top">
      <a class="brand" href="#home"><span></span>{profile.handle}</a>
      <div>{profile.nav.map(([label, href]) => <a href={href}>{label}</a>)}</div>
    </nav>
    <main id="home">
      <header class="hero">
        <div class="copy">
          <p class="eyebrow">{profile.role} at {profile.company} / {profile.location}</p>
          <h1>I build software that feels sharp, useful, and maintainable.</h1>
          <p class="lead">{profile.summary}</p>
          <div class="actions">{profile.links.map(([label, href]) => <a href={href}>{label}</a>)}</div>
        </div>
        <aside class="panel">
          <img src={profile.avatar} alt={profile.name} />
          <h2>{profile.name}</h2>
          <p>@{profile.handle}</p>
          <div class="stats">{profile.stats.map(([n, label]) => <p><strong>{n}</strong><span>{label}</span></p>)}</div>
        </aside>
      </header>
      <section class="console">
        <div><span>~/github/BatmiBoom</span><strong>{profile.stack.join(" / ")}</strong></div>
        <ul>{profile.terminal.map((line) => <li>{line}</li>)}</ul>
      </section>
      <Section title="Work" items={profile.work} />
      <section id="projects" class="section">
        <h2>Projects</h2>
        <div class="projects">
          {profile.projects.map(([name, text, stack, href]) => <a class="project" href={href}><span>{stack}</span><strong>{name}</strong><p>{text}</p></a>)}
        </div>
      </section>
      <Section title="Principles" items={profile.principles} />
    </main>
    <footer id="contact">
      <p>{year} / {profile.name}</p>
      <div>{profile.links.map(([label, href]) => <a href={href}>{label}</a>)}</div>
    </footer>
  </body>
</html>
<style>
  :root{--bg:#080b0f;--ink:#f4f0e7;--muted:#aab3ad;--line:#26322f;--card:#101821;--green:#49d49d;--blue:#6aa6ff;--red:#ff6b55;--paper:#f2e8cd}
  *{box-sizing:border-box} html{scroll-behavior:smooth} body{margin:0;background:linear-gradient(115deg,#080b0f 0 54%,#112116 54% 55%,#0c121a 55% 100%);color:var(--ink);font:16px/1.55 ui-sans-serif,system-ui,sans-serif} body:before{content:"";position:fixed;inset:0;pointer-events:none;background:linear-gradient(#ffffff08 1px,transparent 1px),linear-gradient(90deg,#ffffff08 1px,transparent 1px);background-size:44px 44px;mask-image:linear-gradient(to bottom,#000,transparent 80%)}
  a{color:inherit;text-decoration:none}.top,main,footer{width:min(1180px,calc(100% - 32px));margin:auto}.top{position:sticky;top:0;z-index:2;display:flex;align-items:center;justify-content:space-between;gap:18px;padding:18px 0;background:#080b0fcc;backdrop-filter:blur(18px)}
  .brand{display:flex;align-items:center;gap:10px;color:var(--green);font-weight:950}.brand span{width:12px;height:12px;background:var(--green);box-shadow:0 0 24px var(--green)}.top div,.actions,footer div{display:flex;gap:10px;flex-wrap:wrap}.top a,.actions a,footer a{border:1px solid var(--line);border-radius:8px;padding:10px 13px;font-size:.78rem;font-weight:900;text-transform:uppercase}.top div a:hover,.actions a:hover,.project:hover{border-color:var(--green);transform:translateY(-2px)}
  .hero{min-height:86vh;display:grid;grid-template-columns:minmax(0,1.15fr) 380px;gap:50px;align-items:center;padding:58px 0}.eyebrow,h2,.project span{margin:0;color:var(--green);font-size:.78rem;font-weight:950;text-transform:uppercase;letter-spacing:0}
  h1{max-width:11ch;margin:.08em 0 .24em;font-size:clamp(4rem,9vw,8.8rem);line-height:.82}.lead{max-width:62ch;color:var(--muted);font-size:clamp(1.1rem,2vw,1.35rem)}.actions{margin-top:30px}.actions a:first-child{background:var(--green);color:#05100d;border-color:var(--green)}
  .panel{position:relative;padding:14px;border:1px solid var(--line);border-radius:8px;background:linear-gradient(180deg,#172330,#0d141c);box-shadow:24px 24px 0 #0008}.panel:before{content:"public_profile.ts";display:block;margin:-14px -14px 14px;padding:10px 14px;border-bottom:1px solid var(--line);color:var(--muted);font:700 .8rem ui-monospace,monospace}.panel img{width:100%;aspect-ratio:1;object-fit:cover;border-radius:6px;filter:saturate(1.12) contrast(1.05)}.panel h2{margin:16px 0 0;color:var(--ink);font-size:1.4rem;text-transform:none}.panel>p{margin:2px 0 16px;color:var(--muted)}
  .stats,.grid,.projects{display:grid;gap:12px}.stats{grid-template-columns:repeat(2,1fr)}.stats p,.grid article,.project,.console{margin:0;padding:16px;border:1px solid var(--line);border-radius:8px;background:color-mix(in srgb,var(--card) 88%,transparent)}.stats strong{display:block;color:var(--paper);font-size:1.35rem}.stats span,.grid p,.project p{color:var(--muted)}
  .console{display:grid;grid-template-columns:.75fr 1.25fr;gap:20px;margin-bottom:26px;font-family:ui-monospace,monospace}.console span{display:block;color:var(--red);margin-bottom:8px}.console strong{color:var(--paper)}.console ul{margin:0;padding-left:18px;color:var(--muted)}
  .section{padding:58px 0;border-top:1px solid var(--line)}h2{margin-bottom:18px}.grid{grid-template-columns:repeat(3,1fr)}.grid article{min-height:140px}.grid strong,.project strong{display:block;color:var(--paper);font-size:1.35rem}.projects{grid-template-columns:repeat(3,1fr)}.project{min-height:220px;display:flex;flex-direction:column;justify-content:space-between;transition:.18s ease}.project:nth-child(3n+2){background:#121b15}.project:nth-child(3n){background:#15141d}
  footer{display:flex;justify-content:space-between;gap:18px;padding:36px 0 52px;border-top:1px solid var(--line);color:var(--muted)}footer p{margin:0}
  @media (max-width:860px){.top,footer{align-items:flex-start;flex-direction:column}.hero,.console,.grid,.projects,.stats{grid-template-columns:1fr}.hero{min-height:auto;padding:44px 0}.panel{box-shadow:12px 12px 0 #0008}h1{font-size:4.1rem}.top div a{padding:8px 10px}}
</style>
