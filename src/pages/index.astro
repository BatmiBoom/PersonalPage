---
import Section from "../components/Section.astro";
import { profile } from "../content/profile";
const year = new Date().getFullYear();
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={`${profile.name} - ${profile.role}`} />
    <title>{profile.name}</title>
  </head>
  <body>
    <nav class="top">
      <a class="brand" href="#home">{profile.handle}</a>
      <div>{profile.nav.map(([label, href]) => <a href={href}>{label}</a>)}</div>
    </nav>
    <main id="home">
      <header class="hero">
        <div class="copy">
          <p class="eyebrow">{profile.role} at {profile.company} / {profile.location}</p>
          <h1>{profile.name}</h1>
          <p class="lead">{profile.summary}</p>
          <div class="actions">{profile.links.map(([label, href]) => <a href={href}>{label}</a>)}</div>
        </div>
        <div class="portrait">
          <img src={profile.avatar} alt={profile.name} />
          <div class="stats">{profile.stats.map(([n, label]) => <p><strong>{n}</strong><span>{label}</span></p>)}</div>
        </div>
      </header>
      <Section title="Work" items={profile.work} />
      <section id="projects" class="section">
        <h2>Projects</h2>
        <div class="projects">
          {profile.projects.map(([name, text, stack, href]) => <a class="project" href={href}><span>{stack}</span><strong>{name}</strong><p>{text}</p></a>)}
        </div>
      </section>
      <Section title="Principles" items={profile.principles} />
    </main>
    <footer id="contact">
      <p>{year} / {profile.name}</p>
      <div>{profile.links.map(([label, href]) => <a href={href}>{label}</a>)}</div>
    </footer>
  </body>
</html>
<style>
  :root{--ink:#111814;--muted:#617068;--paper:#f6f2e8;--card:#fffaf0;--line:#d8d1c1;--accent:#0f7b65;--hot:#bf4d2f}
  *{box-sizing:border-box} html{scroll-behavior:smooth} body{margin:0;background:radial-gradient(circle at 80% 0,#dff1e9 0 18rem,transparent 30rem),var(--paper);color:var(--ink);font:16px/1.55 Inter,ui-sans-serif,system-ui,sans-serif}
  a{color:inherit;text-decoration:none}.top,main,footer{width:min(1120px,calc(100% - 32px));margin:auto}.top{position:sticky;top:0;z-index:2;display:flex;justify-content:space-between;gap:16px;padding:18px 0;background:color-mix(in srgb,var(--paper) 84%,transparent);backdrop-filter:blur(14px)}
  .top div,.actions,footer div{display:flex;gap:10px;flex-wrap:wrap}.top a,.actions a,footer a{border:1px solid var(--line);border-radius:8px;padding:9px 12px;font-weight:800;font-size:.78rem;text-transform:uppercase}.brand{border-color:transparent!important;color:var(--accent)}
  .hero{min-height:82vh;display:grid;grid-template-columns:1.15fr .85fr;gap:42px;align-items:center;padding:52px 0 70px}.eyebrow,h2,.project span{margin:0;color:var(--hot);font-size:.78rem;font-weight:900;text-transform:uppercase;letter-spacing:0}
  h1{margin:.12em 0 .2em;font-size:clamp(3.4rem,8vw,7.8rem);line-height:.88;max-width:8ch}.lead{max-width:58ch;font-size:clamp(1.1rem,2vw,1.45rem);color:var(--muted)}.actions{margin-top:28px}
  .portrait{display:grid;gap:14px}.portrait img{width:100%;aspect-ratio:4/5;object-fit:cover;border-radius:8px;border:1px solid var(--line);box-shadow:18px 18px 0 #10231d}
  .stats,.grid,.projects{display:grid;grid-template-columns:repeat(4,1fr);gap:12px}.stats p,.grid article,.project{min-height:118px;margin:0;padding:16px;border:1px solid var(--line);border-radius:8px;background:var(--card)}.stats strong{display:block;font-size:1.35rem}.stats span,.grid p,.project p{color:var(--muted)}
  .section{padding:54px 0;border-top:1px solid var(--line)}h2{margin-bottom:18px}.grid{grid-template-columns:repeat(3,1fr)}.projects{grid-template-columns:repeat(3,1fr)}.project{display:flex;flex-direction:column;gap:10px}.project strong{font-size:1.35rem}
  footer{display:flex;justify-content:space-between;gap:18px;padding:34px 0 48px;border-top:1px solid var(--line);color:var(--muted)}
  @media (max-width:820px){.top,footer{align-items:flex-start;flex-direction:column}.hero,.grid,.projects,.stats{grid-template-columns:1fr}.hero{min-height:auto;padding-top:36px}.portrait img{max-height:420px}.top div a{padding:8px 10px}h1{font-size:3.6rem}}
</style>
