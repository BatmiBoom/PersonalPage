---
import Section from "../components/Section.astro";
import { profile } from "../content/profile";
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={`${profile.name} - ${profile.role}`} />
    <title>{profile.name}</title>
  </head>
  <body>
    <main>
      <header>
        <img src={profile.avatar} alt={profile.name} />
        <div>
          <p class="eyebrow">{profile.role} / {profile.location}</p>
          <h1>{profile.name}</h1>
          <p>{profile.summary}</p>
          <nav>{profile.links.map(([label, href]) => <a href={href}>{label}</a>)}</nav>
        </div>
      </header>
      <Section title="Focus" items={profile.strengths} />
      <Section title="How I Work" items={profile.principles} />
      <Section title="Now" items={profile.work} />
    </main>
  </body>
</html>
<style>
  :root{color-scheme:light;--ink:#17211f;--muted:#5b6864;--line:#d8ded8;--paper:#f7f5ef;--accent:#26735f}
  *{box-sizing:border-box} body{margin:0;background:var(--paper);color:var(--ink);font:16px/1.55 Inter,ui-sans-serif,system-ui,sans-serif}
  main{width:min(1040px,calc(100% - 32px));margin:auto;padding:56px 0}
  header{min-height:68vh;display:grid;grid-template-columns:220px 1fr;gap:48px;align-items:center;border-bottom:1px solid var(--line)}
  img{width:220px;aspect-ratio:1;border-radius:8px;object-fit:cover;border:1px solid var(--line)}
  .eyebrow,a,h2{font-size:.8rem;text-transform:uppercase;letter-spacing:0;color:var(--accent);font-weight:800}
  h1{font-size:clamp(3rem,7vw,6.8rem);line-height:.92;margin:.1em 0 .22em;max-width:8ch}
  header p:not(.eyebrow){font-size:clamp(1.1rem,2vw,1.35rem);max-width:52ch;color:var(--muted)}
  nav,.grid{display:flex;gap:12px;flex-wrap:wrap} a{padding:10px 14px;border:1px solid var(--accent);border-radius:8px;text-decoration:none}
  section{padding:42px 0;border-bottom:1px solid var(--line)} h2{margin:0 0 16px}
  article{flex:1 1 220px;min-height:116px;padding:18px;border:1px solid var(--line);border-radius:8px;background:#fffdf8}
  strong{display:block;margin-bottom:8px} article p{margin:0;color:var(--muted)}
  @media (max-width:720px){main{padding:28px 0}header{grid-template-columns:1fr;gap:24px;align-content:center}img{width:140px}h1{font-size:3.2rem}}
</style>
